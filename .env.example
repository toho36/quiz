# Public env (safe for the browser bundle)
# Required for every build: local | preview | production
NEXT_PUBLIC_APP_ENV=local
# Required for every build: must be an absolute URL for the current deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional public env
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_SPACETIME_ENDPOINT=https://maincloud.spacetimedb.com

# Server-only env (never expose via NEXT_PUBLIC_*)
CLERK_SECRET_KEY=
SPACETIME_DATABASE=quiz-1j871
SPACETIME_ADMIN_TOKEN=
RUNTIME_BOOTSTRAP_SIGNING_KEY=
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=quiz